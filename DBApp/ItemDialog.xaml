<Window x:Class="DBApp.ItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DBApp"
        mc:Ignorable="d"
        Title="ItemDialog" Height="320" Width="320">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Text="Фамилия" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="2"/>
        <TextBox x:Name="FirstNameTB" Grid.Row="1" Margin="2"/>

        <TextBlock Text="Имя" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Grid.Row="2" Margin="2"/>
        <TextBox x:Name="LastNameTB" Grid.Row="3" Margin="2"/>

        <TextBlock Text="Дата рождения" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Grid.Row="4" Margin="2"/>
        <DatePicker x:Name="BirthDateDP" Grid.Row="5" Margin="2"/>

        <TextBlock Text="Группа" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Grid.Row="6" Margin="2"/>
        <ComboBox x:Name="GroupCB" Grid.Row="7" Margin="2"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
            <Button x:Name="CancelBTN" Content="Cancel" Width="80" Margin="10 0 10 0" Background="DarkGray" Click="CancelBTN_Click"/>
            <Button x:Name="SaveBTN" Content="Save" Width="80" Margin="10 0 10 0" Background="LightGreen" Click="SaveBTN_Click"/>
        </StackPanel>

    </Grid>
</Window>
